<UserControl x:Class="GuardianEye.Admin.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GuardianEye.Admin.Views.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        
        <TextBlock Text="Dashboard Overview" 
                   FontSize="24" 
                   FontWeight="Bold"
                   Foreground="White" 
                   Grid.Row="0" 
                   Grid.ColumnSpan="3"/>
        
        <!-- Stats Cards -->
        <Border Grid.Row="1" Grid.Column="0" Background="#FF1E1E20" CornerRadius="10" Padding="20">
            <StackPanel>
                <TextBlock Text="Total Students" Foreground="#FF888888" FontSize="14"/>
                <TextBlock Text="0" Foreground="White" FontSize="36" FontWeight="Bold"/>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="1" Grid.Column="2" Background="#FF1E1E20" CornerRadius="10" Padding="20">
            <StackPanel>
                <TextBlock Text="Active Sessions" Foreground="#FF888888" FontSize="14"/>
                <TextBlock Text="0" Foreground="White" FontSize="36" FontWeight="Bold"/>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="3" Grid.Column="0" Background="#FF1E1E20" CornerRadius="10" Padding="20">
            <StackPanel>
                <TextBlock Text="Pending Requests" Foreground="#FF888888" FontSize="14"/>
                <TextBlock Text="0" Foreground="#FF0078D4" FontSize="36" FontWeight="Bold"/>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="3" Grid.Column="2" Background="#FF1E1E20" CornerRadius="10" Padding="20">
            <StackPanel>
                <TextBlock Text="Offline Devices" Foreground="#FF888888" FontSize="14"/>
                <TextBlock Text="0" Foreground="#FFD13438" FontSize="36" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>