<UserControl x:Class="GuardianEye.Admin.Views.Pages.StudentsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GuardianEye.Admin.Views.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Text="Student Management" 
                   FontSize="24" 
                   FontWeight="Bold"
                   Foreground="White" 
                   Grid.Row="0" 
                   Margin="0,0,0,10"/>
        
        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="SearchTextBox" Width="250" Height="30" 
                     VerticalAlignment="Center" 
                     VerticalContentAlignment="Center"
                     FontSize="14"
                     Padding="8,0"
                     Background="#FF3D3D40"
                     Foreground="White"
                     BorderBrush="#FF555555"
                     BorderThickness="1"/>
            <ComboBox x:Name="StatusFilterComboBox" Width="120" Height="30" 
                      Margin="10,0,0,0"
                      VerticalAlignment="Center"
                      FontSize="14">
                <ComboBoxItem Content="All Status" IsSelected="True"/>
                <ComboBoxItem Content="Active"/>
                <ComboBoxItem Content="Inactive"/>
            </ComboBox>
            <ComboBox x:Name="ClassFilterComboBox" Width="120" Height="30" 
                      Margin="10,0,0,0"
                      VerticalAlignment="Center"
                      FontSize="14">
                <ComboBoxItem Content="All Classes" IsSelected="True"/>
            </ComboBox>
            <Button x:Name="AddStudentButton" Content="Add Student" 
                    Width="100" Height="30" 
                    Margin="15,0,0,0"
                    Background="#FF0078D4"
                    Foreground="White"
                    Cursor="Hand"/>
        </StackPanel>
        
        <!-- Students DataGrid -->
        <DataGrid x:Name="StudentsDataGrid" 
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Background="#FF2D2D30"
                  Foreground="White"
                  BorderBrush="#FF555555"
                  BorderThickness="1"
                  RowHeight="40"
                  FontSize="14">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*"/>
                <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="2*"/>
                <DataGridTextColumn Header="Student ID" Binding="{Binding StudentId}" Width="120"/>
                <DataGridTextColumn Header="Class" Binding="{Binding Class}" Width="100"/>
                <DataGridTextColumn Header="Sessions" Binding="{Binding SessionsUsedToday}" Width="80"/>
                <DataGridTextColumn Header="Max Sessions" Binding="{Binding MaxDailySessions}" Width="100"/>
                <DataGridTextColumn Header="Duration (min)" Binding="{Binding SessionDurationMinutes}" Width="100"/>
                <DataGridTextColumn Header="Status" Binding="{Binding IsActive}" Width="80"/>
                <DataGridTemplateColumn Header="Actions" Width="250">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Edit" Margin="2" Padding="8,4" FontSize="12" Background="#FF0078D4" Foreground="White"/>
                                <Button Content="Reset" Margin="2" Padding="8,4" FontSize="12" Background="#FFED9A00" Foreground="White"/>
                                <Button Content="Logout" Margin="2" Padding="8,4" FontSize="12" Background="#FFD13438" Foreground="White"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>