<Window x:Class="GuardianEye.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:GuardianEye.ViewModels"
        mc:Ignorable="d"
        Title="GuardianEye - Login" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>
    <Border Background="#1E1E2F" CornerRadius="15" Effect="{DynamicResource DropShadow}">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,0">
                <TextBlock Text="GuardianEye" FontSize="32" FontWeight="Bold" 
                           Foreground="#00D4FF" HorizontalAlignment="Center"/>
                <TextBlock Text="Student Monitoring System" FontSize="14" 
                           Foreground="#888888" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

             <StackPanel Grid.Row="1" Margin="0,30,0,0">
                <TextBlock Text="Username" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameBox" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                         Background="#2D2D44" Foreground="White" BorderBrush="#444466" 
                         BorderThickness="1" Height="40" Padding="10"/>
                
                <TextBlock Text="Password" Foreground="#CCCCCC" Margin="0,15,0,5"/>
                <PasswordBox x:Name="PasswordBox" 
                             Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Background="#2D2D44" Foreground="White" BorderBrush="#444466"
                             BorderThickness="1" Height="40" Padding="10"/>
                
                <CheckBox Content="Remember me" Foreground="#888888" Margin="0,10,0,0"
                          IsChecked="{Binding RememberMe}"/>
                
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF5555" 
                           Margin="0,10,0,0" Height="20"/>
                
                <Button Content="LOGIN" Command="{Binding LoginCommand}" 
                        Background="#00D4FF" Foreground="#1E1E2F" 
                        BorderThickness="0" Height="45" Margin="0,20,0,0"
                        FontWeight="Bold" FontSize="16">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Opacity" Value="0.5"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                
                <TextBlock x:Name="SessionStatusText" Text="" Foreground="#888888" 
                           Margin="0,15,0,0" FontSize="11" HorizontalAlignment="Center"/>
            </StackPanel>

            <Border Grid.Row="2" Background="#00D4FF" Opacity="0.1" VerticalAlignment="Bottom" 
                   Height="50" CornerRadius="0,0,15,15"/>
        </Grid>
    </Border>
</Window>