<Window x:Class="GuardianEye.Views.DeveloperOverlayWindow"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:vm="clr-namespace:GuardianEye.ViewModels"
              mc:Ignorable="d"
              Title="Developer Override" 
              Height="220" Width="260"
              WindowStyle="None"
              ResizeMode="NoResize"
              ShowInTaskbar="False"
              Topmost="True"
              SizeToContent="WidthAndHeight"
              AllowsTransparency="True"
              Background="Transparent">
     
    <Border Background="#1E1E2F" 
            BorderBrush="#00D4FF" 
            BorderThickness="1" 
            CornerRadius="8">
        <DockPanel Margin="10">
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                <TextBlock Text="Developer Override" 
                           Foreground="#00D4FF" 
                           FontWeight="Bold" 
                           FontSize="14" 
                           VerticalAlignment="Center"/>
                <Button Content="✕" 
                        Command="{Binding CloseOverlayCommand}"
                        Style="{StaticResource SmallButton}"
                        Width="25" Height="25"
                        HorizontalAlignment="Right"
                        Padding="0"/>
            </DockPanel>
            
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                <Button Content="+15 MINUTES" 
                        Command="{Binding ExtendSessionCommand}"
                        Style="{StaticResource SmallButton}" 
                        Margin="0,2"
                        Height="35"/>
                <Button Content="+1 SESSION" 
                        Command="{Binding AddSessionCommand}"
                        Style="{StaticResource SmallButton}" 
                        Margin="0,2"
                        Height="35"/>
                <Button Content="PAUSE ENFORCEMENT" 
                        Command="{Binding PauseEnforcementCommand}"
                        Style="{StaticResource SmallButton}" 
                        Margin="0,2"
                        Height="35"/>
                <Button Content="UNLOCK SCREEN" 
                        Command="{Binding UnlockScreenCommand}"
                        Style="{StaticResource SmallButton}" 
                        Margin="0,2"
                        Height="35"/>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>