<Window x:Class="GuardianEye.Views.DeveloperOverlayWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:GuardianEye.ViewModels"
             mc:Ignorable="d"
             Title="Developer Override" 
             Height="200" Width="280"
             WindowStyle="None"
             ResizeMode="NoResize"
             ShowInTaskbar="False"
             Topmost="True"
             SizeToContent="WidthAndHeight"
             AllowsTransparency="True"
             Background="Transparent">
    
    <Window.DataContext>
        <vm:DeveloperOverlayViewModel/>
    </Window.DataContext>

    <Border Background="#1E1E2F" 
            BorderBrush="#00D4FF" 
            BorderThickness="1" 
            CornerRadius="10">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Developer Override" 
                       Foreground="#00D4FF" 
                       FontWeight="Bold" 
                       FontSize="14" 
                       Grid.Row="0"/>

            <TextBlock Text="{Binding StatusMessage}" 
                       Foreground="#888888" 
                       FontSize="11" 
                       Grid.Row="1" 
                       Margin="0,5,0,10"/>

            <StackPanel Grid.Row="2" Margin="0,5">
                <Button Content="+15 Minutes" 
                        Command="{Binding ExtendSessionCommand}"
                        Style="{StaticResource SmallButton}" 
                        Margin="0,2"/>
                <Button Content="+1 Session" 
                        Command="{Binding AddSessionCommand}"
                        Style="{StaticResource SmallButton}" 
                        Margin="0,2"/>
                <Button Content="Pause Enforcement (5 min)" 
                        Command="{Binding PauseEnforcementCommand}"
                        Style="{StaticResource SmallButton}" 
                        Margin="0,2"/>
                <Button Content="Unlock Screen" 
                        Command="{Binding UnlockScreenCommand}"
                        Style="{StaticResource SmallButton}" 
                        Margin="0,2"/>
            </StackPanel>

            <TextBlock Text="ESC to close • Auto-close after 10s inactivity" 
                       Foreground="#555555" 
                       FontSize="10" 
                       Grid.Row="3" 
                       HorizontalAlignment="Center" 
                       Margin="0,10,0,0"/>
        </Grid>
    </Border>
</Window>