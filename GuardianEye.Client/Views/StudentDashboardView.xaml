<Window x:Class="GuardianEye.Views.StudentDashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="GuardianEye"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        WindowState="Maximized"
        Background="Transparent">

    <Border Background="#16162A">
        <Grid>
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">

                <Border Background="#22223A"
                        CornerRadius="20"
                        Padding="45,50">
                    <Border.Effect>
                        <DropShadowEffect Color="#00D4FF" Direction="0" ShadowDepth="0"
                                          BlurRadius="40" Opacity="0.08"/>
                    </Border.Effect>

                    <StackPanel HorizontalAlignment="Center">

                        <TextBlock Text="TIME REMAINING"
                                   FontSize="11"
                                   Foreground="#8888AA"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="{Binding RemainingTimeText}"
                                   FontSize="72"
                                   FontWeight="Light"
                                   Foreground="{Binding TimeDisplayColor}"
                                   HorizontalAlignment="Center"
                                   FontFamily="Segoe UI Light"
                                   Margin="0,0,0,8"/>

                        <Border Height="1"
                                Background="#2A2A44"
                                Margin="40,0,40,0"
                                CornerRadius="0.5">
                            <Border Width="60" Height="1" Background="#4444AA" HorizontalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="SESSIONS REMAINING"
                                   FontSize="11"
                                   Foreground="#8888AA"
                                   HorizontalAlignment="Center"
                                   Margin="0,24,0,8"/>

                        <TextBlock Text="{Binding SessionsUsedText}"
                                   FontSize="28"
                                   FontWeight="Light"
                                   Foreground="#CCCCEE"
                                   HorizontalAlignment="Center"
                                   FontFamily="Segoe UI Light"
                                   Margin="0,0,0,36"/>

                        <Border CornerRadius="30"
                                        Background="#2A2A55"
                                        BorderThickness="1"
                                        BorderBrush="#00D4FF"
                                        Height="48" Width="260"
                                        Margin="0,0,0,14">
                                <Button Content="REQUEST MORE TIME"
                                        Command="{Binding RequestMoreTimeCommand}"
                                        Background="Transparent"
                                        Foreground="#00D4FF"
                                        BorderThickness="0"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Height="48"/>
                            </Border>

                            <Border CornerRadius="30"
                                    Background="Transparent"
                                    BorderThickness="1"
                                    BorderBrush="#CC4444"
                                    Height="44" Width="160"
                                    HorizontalAlignment="Center">
                                <Button Content="LOGOUT"
                                        Command="{Binding LogoutCommand}"
                                        Background="Transparent"
                                        Foreground="#CC4444"
                                        BorderThickness="0"
                                        FontSize="12"
                                        FontWeight="Normal"
                                        Cursor="Hand"
                                        Height="44"/>
                            </Border>

                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>