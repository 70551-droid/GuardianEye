<Window x:Class="GuardianEye.Views.StudentDashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="GuardianEye - Student Session" Height="480" Width="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True">
    <Grid>
        <Border Background="#1E1E2F" CornerRadius="18">
            <Border.Effect>
                <DropShadowEffect Color="#000" Direction="270" ShadowDepth="3" BlurRadius="15" Opacity="0.4"/>
            </Border.Effect>
            <Grid Margin="36">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Content="End Session" Command="{Binding LogoutCommand}"
                            Background="#FF4444" Foreground="White" 
                            BorderThickness="0" Height="36" Padding="20,0"
                            FontWeight="Bold" FontSize="13" Cursor="Hand"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding WelcomeMessage}" FontSize="30" 
                           FontWeight="Bold" Foreground="#00D4FF" HorizontalAlignment="Center"
                           Margin="0,10,0,20"/>

                <StackPanel Grid.Row="2" VerticalAlignment="Center">
                    <Border Background="#2D2D44" CornerRadius="14" Padding="40">
                        <StackPanel>
                            <TextBlock Text="Time Remaining" FontSize="13" 
                                       Foreground="#888888" HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="{Binding RemainingTimeText}" FontSize="60" 
                                       Foreground="{Binding TimeDisplayColor}"
                                       FontWeight="Bold" HorizontalAlignment="Center"
                                       Margin="0,0,0,0"/>

                            <TextBlock Text="{Binding WarningMessage}" FontSize="14" 
                                       Foreground="#FF5555" HorizontalAlignment="Center"
                                       Margin="0,8,0,0"
                                       Visibility="{Binding ShowWarning, Converter={StaticResource BoolToVis}}"/>

                            <TextBlock Text="{Binding SessionsUsedText}" Foreground="#AAAAAA" 
                                       HorizontalAlignment="Center" Margin="0,10,0,0"
                                       FontSize="13"/>

                            <ProgressBar Value="{Binding RemainingMinutes}" Maximum="15" 
                                         Height="14" Margin="0,24,0,0" 
                                         Foreground="#00D4FF" Background="#252538"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Row="3" Background="#00D4FF" Height="5" CornerRadius="2,2,18,18"/>
            </Grid>
        </Border>
    </Grid>
</Window>